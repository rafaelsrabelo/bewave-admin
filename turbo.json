{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "test": {
      "dependsOn": ["^build"]
    },
    "db:migrate": { "cache": false },
    "db:generate": { "cache": false },
    "db:studio": { "cache": false, "persistent": true },
    "db:seed": { "cache": false }
  }
}
